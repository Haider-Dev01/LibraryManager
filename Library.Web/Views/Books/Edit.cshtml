@model Library.Web.Models.BookViewModel
@{
    ViewData["Title"] = "Modifier un Livre";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header bg-warning text-dark">
                <h4 class="mb-0"><i class="fas fa-edit me-2"></i>Modifier : @Model.Title</h4>
            </div>
            <div class="card-body">
                <form asp-action="Edit">
                    <input type="hidden" asp-for="Id" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="row g-3">
                        <div class="col-12">
                            <label asp-for="Title" class="form-label fw-bold"></label>
                            <input asp-for="Title" class="form-control" />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Author" class="form-label fw-bold"></label>
                            <input asp-for="Author" class="form-control" />
                            <span asp-validation-for="Author" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ISBN" class="form-label fw-bold"></label>
                            <input asp-for="ISBN" class="form-control" />
                            <span asp-validation-for="ISBN" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="PublicationYear" class="form-label fw-bold"></label>
                            <input asp-for="PublicationYear" class="form-control" type="number" />
                            <span asp-validation-for="PublicationYear" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Genre" class="form-label fw-bold"></label>
                            <input asp-for="Genre" class="form-control" />
                            <span asp-validation-for="Genre" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <div class="form-check form-switch">
                                <input asp-for="IsAvailable" class="form-check-input" type="checkbox" />
                                <label asp-for="IsAvailable" class="form-check-label fw-bold"></label>
                            </div>
                        </div>
                    </div>

                    <div class="mt-4 d-flex gap-2">
                        <button type="submit" class="btn btn-warning">
                            <i class="fas fa-save me-1"></i>Enregistrer
                        </button>
                        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">
                            <i class="fas fa-arrow-left me-1"></i>Annuler
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}