@model Library.Web.Models.BookViewModel
@{
    ViewData["Title"] = "Détails du Livre";
    var loans = ViewBag.Loans as List<Library.Web.Models.LoanViewModel>;
}

<div class="row">
    <div class="col-md-5">
        <div class="card mb-4">
            <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="fas fa-book me-2"></i>Informations</h5>
                @if (Model.IsAvailable)
                {
                    <span class="badge bg-success">Disponible</span>
                }
                else
                {
                    <span class="badge bg-danger">Emprunté</span>
                }
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Titre</dt>
                    <dd class="col-sm-8">@Model.Title</dd>
                    <dt class="col-sm-4">Auteur</dt>
                    <dd class="col-sm-8">@Model.Author</dd>
                    <dt class="col-sm-4">ISBN</dt>
                    <dd class="col-sm-8"><code>@Model.ISBN</code></dd>
                    <dt class="col-sm-4">Année</dt>
                    <dd class="col-sm-8">@Model.PublicationYear</dd>
                    <dt class="col-sm-4">Genre</dt>
                    <dd class="col-sm-8">@Model.Genre</dd>
                    <dt class="col-sm-4">Emprunts</dt>
                    <dd class="col-sm-8">@Model.TotalLoans total</dd>
                </dl>
            </div>
            <div class="card-footer d-flex gap-2 flex-wrap">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning btn-sm">
                    <i class="fas fa-edit me-1"></i>Modifier
                </a>
                @if (Model.IsAvailable)
                {
                    <a asp-controller="Loans" asp-action="Create" asp-route-bookId="@Model.Id"
                           class="btn btn-success btn-sm">
                        <i class="fas fa-hand-holding me-1"></i>Emprunter
                    </a>
                }
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
                    <i class="fas fa-arrow-left me-1"></i>Retour
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-7">
        <div class="card">
            <div class="card-header bg-dark text-white">
                <h5 class="mb-0"><i class="fas fa-history me-2"></i>Historique des Emprunts</h5>
            </div>
            <div class="card-body p-0">
                @if (loans == null || !loans.Any())
                {
                    <p class="text-muted text-center py-4">Aucun emprunt enregistré.</p>
                }
                else
                {
                    <table class="table table-sm table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Emprunteur</th>
                                <th>Date emprunt</th>
                                <th>Retour</th>
                                <th>Statut</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var loan in loans)
                            {
                                <tr>
                                    <td>@loan.BorrowerName</td>
                                    <td>@loan.LoanDate.ToString("dd/MM/yyyy")</td>
                                    <td>
                                        @(loan.ReturnDate.HasValue
                                            ? loan.ReturnDate.Value.ToString("dd/MM/yyyy")
                                            : "-")
                                    </td>
                                    <td>
                                        @if (loan.IsReturned)
                                        {
                                            <span class="badge bg-success">Retourné</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark">En cours (@loan.DaysOnLoan j)</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>
</div>