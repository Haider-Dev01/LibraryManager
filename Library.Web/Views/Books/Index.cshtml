@model Library.Web.Models.BookListViewModel
@{
    ViewData["Title"] = "Gestion des Livres";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h2 class="fw-800 mb-1">Catalogue de Livres</h2>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none">Tableau de bord</a></li>
                <li class="breadcrumb-item active">Livres</li>
            </ol>
        </nav>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="fas fa-plus me-2"></i>Ajouter un Livre
    </a>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4 d-flex align-items-center">
                <div class="bg-primary-subtle p-3 rounded-4 me-4">
                    <i class="fas fa-book-open text-primary fs-3"></i>
                </div>
                <div>
                    <div class="text-muted small fw-bold text-uppercase">Total</div>
                    <div class="h3 mb-0 fw-800">@Model.TotalBooks</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4 d-flex align-items-center">
                <div class="bg-success-subtle p-3 rounded-4 me-4">
                    <i class="fas fa-check-circle text-success fs-3"></i>
                </div>
                <div>
                    <div class="text-muted small fw-bold text-uppercase">Disponibles</div>
                    <div class="h3 mb-0 fw-800">@Model.AvailableBooks</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4 d-flex align-items-center">
                <div class="bg-warning-subtle p-3 rounded-4 me-4">
                    <i class="fas fa-hand-holding text-warning fs-3"></i>
                </div>
                <div>
                    <div class="text-muted small fw-bold text-uppercase">Empruntés</div>
                    <div class="h3 mb-0 fw-800">@Model.BorrowedBooks</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm overflow-hidden">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th class="ps-4">Titre</th>
                    <th>Auteur</th>
                    <th>ISBN</th>
                    <th>Genre</th>
                    <th>Année</th>
                    <th>Statut</th>
                    <th class="text-end pe-4">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var book in Model.Books)
                {
                    <tr>
                        <td class="ps-4">
                            <div class="fw-bold">@book.Title</div>
                        </td>
                        <td>@book.Author</td>
                        <td class="text-muted small">@book.ISBN</td>
                        <td>
                            <span class="badge bg-light text-dark border">@book.Genre</span>
                        </td>
                        <td>@book.PublicationYear</td>
                        <td>
                            @if (book.IsAvailable)
                            {
                                <span class="badge bg-success-subtle text-success rounded-pill border border-success-subtle">
                                    <i class="fas fa-check-circle me-1"></i> Disponible
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-danger-subtle text-danger rounded-pill border border-danger-subtle">
                                    <i class="fas fa-times-circle me-1"></i> Emprunté
                                </span>
                            }
                        </td>
                        <td class="text-end pe-4">
                            <div class="btn-group shadow-sm rounded-3 overflow-hidden">
                                <a asp-action="Details" asp-route-id="@book.Id" class="btn btn-sm btn-white border-end" title="Détails">
                                    <i class="fas fa-eye text-primary"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@book.Id" class="btn btn-sm btn-white border-end" title="Modifier">
                                    <i class="fas fa-edit text-info"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@book.Id" class="btn btn-sm btn-white" title="Supprimer">
                                    <i class="fas fa-trash text-danger"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>